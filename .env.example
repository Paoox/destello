# ============================================================
#  Destello — Variables de Entorno
#  ⚠ NUNCA committear el archivo .env real
#  Copia este archivo: cp .env.example .env
# ============================================================

# ── Entorno ──────────────────────────────────────────────────
NODE_ENV=development           # development | production | staging

# ── URLs ────────────────────────────────────────────────────
# FASE MVP (sin dominio):
#   WEB_URL  = https://destello.vercel.app
#   API_URL  = https://XXXX.trycloudflare.com  ← copiar del tunnel
# FASE PRODUCCIÓN (con dominio):
#   WEB_URL  = https://destello.app
#   API_URL  = https://api.destello.app
WEB_URL=http://localhost:5173
API_URL=http://localhost:3001
VITE_API_URL=http://192.168.1.77:3001

# ── Seguridad ────────────────────────────────────────────────
JWT_SECRET=CAMBIA_ESTO_POR_UN_SECRET_MUY_LARGO_Y_ALEATORIO
JWT_EXPIRES_IN=7d

# ── Base de datos ────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=destello_db
DB_USER=destello
DB_PASSWORD=CAMBIA_ESTO

# ── Redis (cache, sessions) ──────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── OAuth (obtener en developer consoles) ───────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/callback

FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ── Cloudflare Tunnel ────────────────────────────────────────
# Fase MVP: Quick Tunnel — no requiere variables aquí.
# El script setup-cloudflared.sh lo configura como servicio systemd.
# Ver URL activa: sudo journalctl -u destello-tunnel | grep trycloudflare
#
# Fase producción (cuando tengas dominio):
# CF_TUNNEL_TOKEN=       # cloudflared tunnel create destello-prod
# CF_ZONE_ID=            # En Cloudflare dashboard → Overview
# CF_ACCOUNT_ID=         # En Cloudflare dashboard → Overview

# ── API Ports ────────────────────────────────────────────────
API_PORT=3001
VIEWER_3D_PORT=8080

# ── Feature Flags ────────────────────────────────────────────
ENABLE_3D_VIEWER=true
ENABLE_LIVE_CLASS=true
ENABLE_GAMIFICATION=false    # Próximamente

# ── Servicio de correo (nodemailer) ─────────────────────────
# Opción A — Gmail con App Password:
#   1. Activa verificación en 2 pasos en tu cuenta Google
#   2. Ve a myaccount.google.com → Seguridad → Contraseñas de aplicación
#   3. Genera una para "Destello API"
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=tuprocorreo@gmail.com
MAIL_PASS=xxxx_xxxx_xxxx_xxxx   # App Password (16 chars, sin espacios)
MAIL_FROM="Destello ✦ <noreply@destello.mx>"

# ── Admin ────────────────────────────────────────────────────
ADMIN_PASSWORD=CAMBIA_ESTO
ADMIN_TOKEN_SECRET=CAMBIA_ESTO_ADMIN_SECRET

# ── Código demo (eliminar en producción) ────────────────────
DEMO_CODE=DESTELLO2026

# ── Diseño (referencia, los tokens viven en packages/tokens) ─
# PALETA: Jade #0D7377 | Amber #D97706 | Bg #061A18 | Light #FAF7F2